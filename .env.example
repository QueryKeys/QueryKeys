# ============================================================
# QueryKeys — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env!
# ============================================================

# ---- Wallet (L1 Authentication) ----------------------------
# Your Ethereum/Polygon EOA private key (with 0x prefix)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---- Polymarket L2 API Credentials -------------------------
# These are DERIVED from your private key via py-clob-client.
# Run: python scripts/derive_api_keys.py to auto-generate.
POLYMARKET_API_KEY=your-api-key
POLYMARKET_API_SECRET=your-api-secret
POLYMARKET_API_PASSPHRASE=your-api-passphrase

# ---- Anthropic Claude API ----------------------------------
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ---- Optional LLM Fallbacks --------------------------------
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
GROK_API_KEY=YOUR_GROK_KEY

# ---- Sentiment Data Sources --------------------------------
NEWS_API_KEY=YOUR_NEWSAPI_KEY

# ---- Database (optional PostgreSQL override) ---------------
# Leave blank to use default SQLite
DATABASE_URL=

# ---- Monitoring --------------------------------------------
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK
ALERT_EMAIL=you@example.com

# ---- Environment -------------------------------------------
ENVIRONMENT=production   # development | production
LOG_LEVEL=INFO
